# Optional — only DASHBOARD_URL is needed if you store credentials via the bot-config page.
# Copy to .env and set DASHBOARD_URL if self-hosting (otherwise the default Railway URL is used).

# ── Dashboard ─────────────────────────────────────────────────────────────────
# Only needed if self-hosting the dashboard at a different URL
DASHBOARD_URL=https://macrofxmodel-production.up.railway.app

# ── MetaTrader 5 (fallback — prefer setting these via the Bot Config page) ────
# These are only used if credentials haven't been saved to KV via the dashboard.
MT5_ACCOUNT=
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=
