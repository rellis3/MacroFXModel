# Copy this file to .env (never commit .env — it contains credentials)
# Then export each variable before running:
#   Windows PowerShell:  $env:MT5_ACCOUNT = "12345678"
#   Linux / Mac bash:    export MT5_ACCOUNT=12345678
#   Or use a shell wrapper that sources this file.

# ── MetaTrader 5 ──────────────────────────────────────────────────────────────
# Account number shown in MT5 → File → Login to Trade Account
MT5_ACCOUNT=12345678

# Password for that account
MT5_PASSWORD=your_password_here

# Broker server name — visible in MT5 login screen dropdown
# Examples: ICMarkets-Demo01   Pepperstone-Demo   XTB-Demo
MT5_SERVER=ICMarkets-Demo01

# Full path to terminal64.exe (optional — leave blank to use running terminal)
# Windows example: C:\Program Files\MetaTrader 5\terminal64.exe
MT5_PATH=

# ── Dashboard ─────────────────────────────────────────────────────────────────
# Override if self-hosting the dashboard elsewhere
DASHBOARD_URL=https://macrofxmodel-production.up.railway.app
