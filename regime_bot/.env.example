# RegimeBot v2 environment configuration
# Copy this file to .env and fill in your values.
# The bot reads .env at startup — restart to pick up changes.
# Lines starting with # are comments and are ignored.

# ── Pair ──────────────────────────────────────────────────────────────────────
# MT5 symbol format (no slash) — must match your broker's symbol name exactly
RB_PAIR=EURUSD
RB_PIP_SIZE=0.0001           # 0.0001 for FX majors, 0.01 for JPY pairs, 0.01 for XAUUSD

# ── MT5 connection ─────────────────────────────────────────────────────────────
RB_MT5_ACCOUNT=123456789
RB_MT5_PASSWORD=your_password
RB_MT5_SERVER=ICMarkets-Demo01
# RB_MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe   # optional on Windows

# ── Telegram ──────────────────────────────────────────────────────────────────
# Create a bot via @BotFather, get the token.
# Get your chat ID from @userinfobot or by sending /start and checking getUpdates.
RB_TELEGRAM_TOKEN=7123456789:AAF_your_bot_token_here
RB_TELEGRAM_CHAT_ID=123456789

# ── Dashboard / KV context ────────────────────────────────────────────────────
# The dashboard API provides Baum-Welch trained HMM params, FRED macro context,
# COT data, and OI walls.  All fetched silently — the bot runs on defaults if
# the dashboard is unreachable.
RB_DASHBOARD_URL=https://macrofxmodel-production.up.railway.app
RB_CONTEXT_REFRESH_MIN=60    # how often to re-fetch context (minutes)

# ── Execution mode ─────────────────────────────────────────────────────────────
RB_LIVE_MODE=false            # false = paper (no real orders), true = live

# ── HMM engine (advanced — defaults match hmm5m-v2.js for FX majors) ──────────
RB_HMM_BARS=300               # number of 1m bars fed into the HMM
RB_HMM_SELF_PROB=0.92         # regime stickiness when using default (non-learned) params
RB_HMM_LINREG_N=50            # linreg slope window (50 bars = 50-min trend)
RB_HMM_ADX_N=50               # ADX smoothing period

# ── Entry conditions ──────────────────────────────────────────────────────────
RB_ENTRY_CONF_MIN=0.90        # minimum macro-adjusted HMM confidence to enter (90%)
RB_ENTRY_VOL_Z_MAX=0.5        # reject entry when vol_z > this (volatility spike guard)
RB_ENTRY_DECAY_MAX=0.25       # reject entry when decay score is already this high
RB_THIN_CONF_BOOST=0.05       # extra confidence required during THIN/ASIA sessions

# ── Decay detector ─────────────────────────────────────────────────────────────
RB_DECAY_WINDOW=10            # rolling window size in 1m bars
RB_DECAY_CONF_WEIGHT=0.40     # weight of confidence-decline component
RB_DECAY_VOL_WEIGHT=0.35      # weight of vol_z-rise component
RB_DECAY_RL_WEIGHT=0.25       # weight of run-length-stall component

# ── Exit conditions ───────────────────────────────────────────────────────────
RB_DECAY_WARNING=0.50         # send Telegram warning when decay reaches this
RB_DECAY_EXIT=0.70            # close position when decay reaches this
RB_REGIME_FLIP_EXIT=true      # also exit if regime flips against position direction

# ── SL / TP ───────────────────────────────────────────────────────────────────
# ATR mode scales the SL with current volatility — preferred.
# Fixed mode uses the same pip count every trade.
RB_SL_METHOD=atr              # 'atr' or 'fixed_pips'
RB_SL_ATR_MULT=1.5            # ATR multiplier  (SL = ATR(20) × 1.5)
RB_SL_ATR_BARS=20             # ATR period in 1m bars
RB_SL_FIXED_PIPS=20           # used when SL_METHOD=fixed_pips
RB_SL_MAX_PIPS=50             # hard cap regardless of method or volatility
RB_TP_RR=1.5                  # TP = SL_distance × TP_RR  (risk:reward ratio)
RB_TP_MAX_PIPS=100            # hard cap for TP distance

# ── Position sizing (account %-risk model) ────────────────────────────────────
# Base lots = (balance × RISK_PCT / 100) / (sl_pips × pip_value_per_lot)
# Final lots = base × decay_discount × macro_mult × cot_mult
# Example: $10,000 balance, 1% risk, 20-pip SL on EURUSD → ~0.50 lots base
RB_RISK_PCT=1.0               # % of balance to risk per trade (before multipliers)
RB_LOT_SIZE_MIN=0.01          # absolute floor (safety net)
RB_LOT_SIZE_MAX=0.50          # absolute ceiling (safety net)

# ── COT directional lot-size multipliers ──────────────────────────────────────
# Applied based on CFTC leveraged-fund net positioning vs trade direction.
# Does NOT hard-block; reduces size when COT disagrees.
RB_COT_ALIGNED_MULT=1.00      # COT positioning agrees with trade direction
RB_COT_NEUTRAL_MULT=0.85      # COT flat, conflicting, or no data
RB_COT_OPPOSED_MULT=0.65      # COT positioning opposes trade direction

# ── OI wall hard-block ────────────────────────────────────────────────────────
# Skips entry if a large options wall is within this many pips of entry price.
# BUY: blocked if a call wall is within OI_WALL_PIPS above entry.
# SELL: blocked if a put wall is within OI_WALL_PIPS below entry.
RB_OI_WALL_PIPS=15

# ── Drawdown / session limits ─────────────────────────────────────────────────
RB_MAX_DAILY_DD_PCT=3.0       # lock trading if daily drawdown hits this %
RB_MAX_SESSION_DD_PCT=5.0     # lock trading if session drawdown hits this %
RB_DD_LOCKOUT_HOURS=3.0       # hours to remain locked after a DD breach
RB_MAX_DAILY_TRADES=5         # maximum trades per calendar day (UTC)
RB_TRADE_COOLDOWN_MIN=60      # minimum minutes between consecutive trades

# ── Timing ────────────────────────────────────────────────────────────────────
RB_SCAN_INTERVAL=60           # seconds between ticks (ideally aligned to the minute boundary)
