# RegimeBot environment configuration
# Copy this file to .env and fill in your values
# The bot reads .env at startup — restart to pick up changes

# ── Pair ──────────────────────────────────────────────────────────────────────
# MT5 symbol format (no slash) — must match your broker's symbol name exactly
RB_PAIR=EURUSD
RB_PIP_SIZE=0.0001           # 0.0001 for FX majors, 0.01 for JPY, 1.0 for XAU/NAS

# ── MT5 connection ─────────────────────────────────────────────────────────────
RB_MT5_ACCOUNT=123456789
RB_MT5_PASSWORD=your_password
RB_MT5_SERVER=ICMarkets-Demo01
# RB_MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe   # optional on Windows

# ── Telegram ──────────────────────────────────────────────────────────────────
# Create a bot via @BotFather, get the token
# Get your chat ID from @userinfobot or by messaging the bot and checking getUpdates
RB_TELEGRAM_TOKEN=7123456789:AAF_your_bot_token_here
RB_TELEGRAM_CHAT_ID=123456789

# ── Execution mode ─────────────────────────────────────────────────────────────
# false = paper mode (no real orders), true = live orders sent to MT5
RB_LIVE_MODE=false

# ── Entry conditions ──────────────────────────────────────────────────────────
RB_ENTRY_CONF_MIN=0.90       # minimum HMM state confidence (90%)
RB_ENTRY_VOL_Z_MAX=0.5       # max vol_z — avoid entering into vol spikes
RB_ENTRY_DECAY_MAX=0.25      # max decay score at entry

# ── Decay detector ─────────────────────────────────────────────────────────────
RB_DECAY_WINDOW=10           # rolling window size in bars
RB_DECAY_CONF_WEIGHT=0.40    # weight of confidence decline component
RB_DECAY_VOL_WEIGHT=0.35     # weight of vol_z rise component
RB_DECAY_RL_WEIGHT=0.25      # weight of run-length stall component

# ── Exit conditions ───────────────────────────────────────────────────────────
RB_DECAY_WARNING=0.50        # decay score that triggers a Telegram warning
RB_DECAY_EXIT=0.70           # decay score that triggers position close
RB_REGIME_FLIP_EXIT=true     # also exit immediately if regime flips against position

# ── Risk / sizing ─────────────────────────────────────────────────────────────
# Lot size scales with regime strength: strong regime → LOT_SIZE_MAX, weak → LOT_SIZE_MIN
RB_LOT_SIZE_BASE=0.01        # baseline (not used directly — see decay scaling)
RB_LOT_SIZE_MIN=0.01
RB_LOT_SIZE_MAX=0.10
RB_SL_PIPS=20
RB_TP_PIPS=40

# ── HMM engine (advanced — defaults match hmm5m.js for FX majors) ─────────────
RB_HMM_BARS=300              # number of 1m bars to feed into HMM
RB_HMM_SELF_PROB=0.92        # regime stickiness (higher = slower to flip)
RB_HMM_LINREG_N=50           # linreg slope window (50 bars = 50m trend)
RB_HMM_ADX_N=50              # ADX smoothing period
RB_HMM_ADX_TARGET=0.5        # bull/bear adxZ emission target

# ── Timing ────────────────────────────────────────────────────────────────────
RB_SCAN_INTERVAL=60          # seconds between ticks (align to minute boundaries)
