# RegimeBot environment configuration
# Copy this file to .env and fill in your values
# The bot reads .env at startup — restart to pick up changes

# ── Pair ──────────────────────────────────────────────────────────────────────
# MT5 symbol format (no slash) — must match your broker's symbol name exactly
RB_PAIR=EURUSD
RB_PIP_SIZE=0.0001           # 0.0001 for FX majors, 0.01 for JPY, 0.01 for XAUUSD

# ── MT5 connection ─────────────────────────────────────────────────────────────
RB_MT5_ACCOUNT=123456789
RB_MT5_PASSWORD=your_password
RB_MT5_SERVER=ICMarkets-Demo01
# RB_MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe   # optional on Windows

# ── Telegram ──────────────────────────────────────────────────────────────────
# Create a bot via @BotFather, get the token
# Get your chat ID from @userinfobot or by messaging the bot and checking getUpdates
RB_TELEGRAM_TOKEN=7123456789:AAF_your_bot_token_here
RB_TELEGRAM_CHAT_ID=123456789

# ── Execution mode ─────────────────────────────────────────────────────────────
RB_LIVE_MODE=false            # false = paper (no real orders), true = live

# ── Entry conditions ──────────────────────────────────────────────────────────
RB_ENTRY_CONF_MIN=0.90        # HMM state confidence gate (90%)
RB_ENTRY_VOL_Z_MAX=0.5        # reject entry when vol_z > this (spike protection)
RB_ENTRY_DECAY_MAX=0.25       # reject entry when decay score already this high

# ── Decay detector ─────────────────────────────────────────────────────────────
RB_DECAY_WINDOW=10            # rolling window size in 1m bars
RB_DECAY_CONF_WEIGHT=0.40     # weight of confidence-decline component
RB_DECAY_VOL_WEIGHT=0.35      # weight of vol_z-rise component
RB_DECAY_RL_WEIGHT=0.25       # weight of run-length-stall component

# ── Exit conditions ───────────────────────────────────────────────────────────
RB_DECAY_WARNING=0.50         # send Telegram warning at this decay score
RB_DECAY_EXIT=0.70            # close position at this decay score
RB_REGIME_FLIP_EXIT=true      # also exit if regime flips against position

# ── SL / TP ───────────────────────────────────────────────────────────────────
# ATR mode scales the SL with current volatility — preferred
# Fixed mode uses the same pip count every trade
RB_SL_METHOD=atr              # 'atr' or 'fixed_pips'
RB_SL_ATR_MULT=1.5            # ATR multiplier  (SL = ATR × 1.5)
RB_SL_ATR_BARS=20             # ATR period in 1m bars
RB_SL_FIXED_PIPS=20           # used when SL_METHOD=fixed_pips
RB_SL_MAX_PIPS=50             # hard cap regardless of method
RB_TP_RR=1.5                  # TP = SL_distance × TP_RR  (risk:reward)
RB_TP_MAX_PIPS=100            # hard cap for TP

# ── Position sizing (account %-risk model) ────────────────────────────────────
# lots = (balance × RISK_PCT / 100) / (sl_pips × pip_value_per_lot)
# Example: $10,000 balance, 1% risk, 20-pip SL on EURUSD → 0.50 lots
RB_RISK_PCT=1.0               # % of balance to risk per trade
RB_LOT_SIZE_MIN=0.01          # floor (safety net)
RB_LOT_SIZE_MAX=0.50          # ceiling (safety net)

# ── Drawdown / session limits ─────────────────────────────────────────────────
RB_MAX_DAILY_DD_PCT=3.0       # lock trading if daily drawdown hits this %
RB_MAX_SESSION_DD_PCT=5.0     # lock trading if session drawdown hits this %
RB_DD_LOCKOUT_HOURS=3.0       # hours to remain locked after a DD breach
RB_MAX_DAILY_TRADES=5         # maximum trades per calendar day (UTC)
RB_TRADE_COOLDOWN_MIN=60      # minimum minutes between consecutive trades

# ── HMM engine (advanced — defaults match hmm5m.js for FX majors) ─────────────
RB_HMM_BARS=300               # number of 1m bars to feed into HMM
RB_HMM_SELF_PROB=0.92         # regime stickiness (higher = slower to flip)
RB_HMM_LINREG_N=50            # linreg slope window (50 bars = 50-minute trend)
RB_HMM_ADX_N=50               # ADX smoothing period
RB_HMM_ADX_TARGET=0.5         # bull/bear adxZ emission target

# ── Timing ────────────────────────────────────────────────────────────────────
RB_SCAN_INTERVAL=60           # seconds between ticks (ideally aligned to minute)
