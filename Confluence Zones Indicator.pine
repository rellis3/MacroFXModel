//@version=6
indicator("C.og - Confluence Zones v1", overlay=true, max_lines_count=500, max_labels_count=500)

// =====================================================
// HOW TO USE
// =====================================================
// 1. On the vol-forecast dashboard, click ⬇ C+Z.
// 2. Paste the copied text into the input below.
// 3. The indicator draws horizontal zones for the
//    current chart symbol — coloured by confluence
//    layer count (yellow=2, orange=3, red/purple=4+).
// 4. POC and NPOC lines are computed live from the
//    chart's own daily bars — no paste needed for those.
// 5. Set Alert Proximity Pips and enable alerts via
//    TradingView's alert panel (any condition → this
//    indicator → "CZ Proximity Alert").
//
// Refresh the paste each trading day (or after major
// moves) to keep C+Z zones aligned to current prices.
// POC/NPOC update automatically each bar.
//
// LEVEL TYPES IN EXPORT:
//   sr     — Swing pivot S/R (2-bar confirmation, 30-day lookback)
//   fib    — Fibonacci from identified swing pivot pairs (recursive)
//   d_open — Previous daily opens (last 5 days)
//   poc    — Approx POC: daily range midpoint (H+L)/2
//   npoc   — Naked POC: unvisited daily midpoints
//   w_piv  — Weekly pivots PP/R1/R2/S1/S2
//   vol_m  — Vol forecast median absolute levels
//   vol_75 — Vol forecast 75th-pct absolute levels
//   round  — Psychological round numbers

// =====================================================
// INPUTS — TICKER MAPPING (match your chart symbols)
// =====================================================

goldChart  = input.string("XAUUSD",    "Gold chart ticker",   group="Symbol Mapping")
nqChart    = input.string("NQ1!",      "NQ chart ticker",     group="Symbol Mapping")
spxChart   = input.string("SPX500USD", "SPX500 chart ticker", group="Symbol Mapping")
de30Chart  = input.string("GER40",     "DE30 chart ticker",   group="Symbol Mapping")
uk100Chart = input.string("UK100GBP",  "UK100 chart ticker",  group="Symbol Mapping")
us30Chart  = input.string("US30USD",   "US30 chart ticker",   group="Symbol Mapping")
us2kChart  = input.string("US2000USD", "US2000 chart ticker", group="Symbol Mapping")

// =====================================================
// INPUT — PASTE C+Z BLOCK FROM DASHBOARD
// =====================================================

czText = input.text_area(
     title  = "Paste C+Z Block (from ⬇ C+Z button)",
     defval =
"──── CONFLUENCE ZONES ─────────────────────────────\n" +
"Generated: 2026-06-18\n" +
"\n" +
"GOLD\n" +
"CZ 2312.50 : 5 fib,sr,d_open,vol_75\n" +
"CZ 2287.30 : 4 fib,d_open,w_piv\n" +
"CZ 2265.10 : 3 fib,round\n" +
"\n" +
"EURUSD\n" +
"CZ 1.08750 : 4 fib,sr,d_open\n" +
"CZ 1.08420 : 3 fib,w_piv"
)

// =====================================================
// STYLE INPUTS
// =====================================================

col_4plus  = input.color(color.new(color.fuchsia, 0),  "4+ Layer Zone Colour",      group="Zone Colours")
col_3      = input.color(color.new(color.orange,  0),  "3 Layer Zone Colour",       group="Zone Colours")
col_2      = input.color(color.new(color.yellow,  0),  "2 Layer Zone Colour",       group="Zone Colours")

zone_width = input.int(2, "Line Width", minval=1, maxval=5, group="Zone Colours")
show_label = input.bool(true, "Show Labels",                   group="Zone Colours")
show_types = input.bool(true, "Show Level Types in Label",     group="Zone Colours")
show_table   = input.bool(true,  "Show Zone Summary Table",       group="Zone Colours")
req_anchor   = input.bool(false, "Only show vol-anchored zones",   group="Zone Colours",
     tooltip="Hides zones that do not include a vol_m or vol_75 level. Unanchored zones are levels of interest only — no statistical engine drives price to them.")
dim_unanchor = input.bool(true,  "Dim unanchored zones",           group="Zone Colours",
     tooltip="When 'Only show vol-anchored' is off: dims unanchored zones rather than hiding them. Toggle off to show all zones at full colour.")

alert_pips       = input.float(3.0, "Alert Proximity (pips)", minval=0.1, step=0.5, group="Alerts",
     tooltip="Fire alert when close comes within this many pips of any zone with count ≥ alert_min_count.")
alert_min_count  = input.int(2, "Min Count for Alert", minval=2, maxval=5, group="Alerts",
     tooltip="Only alert on zones with this many or more distinct level types.")
alert_extend_right = input.bool(true, "Extend Lines Right", group="Alerts")

// =====================================================
// POC / NPOC (computed live from chart's daily bars)
// =====================================================

show_poc      = input.bool(true,  "Show POC Lines",         group="POC / NPOC",
     tooltip="Daily range midpoints (H+L)/2 for the last N complete days.")
show_npoc     = input.bool(true,  "Show NPOC Lines",        group="POC / NPOC",
     tooltip="Naked POC — midpoints that price has not traded through since the day they formed.")
poc_days      = input.int(5,      "POC — Recent Days",      minval=1, maxval=20, group="POC / NPOC")
npoc_lookback = input.int(30,     "NPOC — Lookback (Days)", minval=5, maxval=60,  group="POC / NPOC")
col_poc       = input.color(color.new(color.lime, 40),  "POC Colour",  group="POC / NPOC")
col_npoc      = input.color(color.new(color.teal,  0),  "NPOC Colour", group="POC / NPOC")
poc_lw        = input.int(1, "POC/NPOC Line Width", minval=1, maxval=3, group="POC / NPOC")

// =====================================================
// SYMBOL NORMALISATION
// =====================================================

f_normaliseTicker(t, goldT, nqT, spxT, de30T, uk100T, us30T, us2kT) =>
    r = t
    tU = str.upper(t)
    if tU == str.upper(goldT) or tU == "XAUUSD" or tU == "GOLD"
        r := "GOLD"
    else if tU == str.upper(nqT) or tU == "NQ1!" or tU == "NQ" or tU == "NASDAQ100" or tU == "NAS100USD"
        r := "NQ"
    else if tU == str.upper(spxT) or tU == "SPX500USD" or tU == "US500" or tU == "SP1!"
        r := "SPX500"
    else if tU == str.upper(de30T) or tU == "GER40" or tU == "GER30" or tU == "DE30EUR" or tU == "FDAX1!"
        r := "DE30"
    else if tU == str.upper(uk100T) or tU == "UK100GBP" or tU == "Z1!" or tU == "FTSE100"
        r := "UK100"
    else if tU == str.upper(us30T) or tU == "US30USD" or tU == "DJIA" or tU == "YM1!"
        r := "US30"
    else if tU == str.upper(us2kT) or tU == "US2000USD" or tU == "RTY1!" or tU == "RUT"
        r := "US2000"
    r

// =====================================================
// PIP SIZE (for alert proximity calculation)
// =====================================================

f_pipSize(sym) =>
    symU = str.upper(sym)
    symU == "GOLD"                                   ? 0.1    :
     symU == "NQ" or symU == "US30"                 ? 1.0    :
     symU == "SPX500" or symU == "DE30" or
      symU == "UK100" or symU == "US2000"            ? 1.0    :
     str.contains(symU, "JPY")                       ? 0.01   : 0.0001

// =====================================================
// PARSE C+Z BLOCK
// =====================================================

// Known ticker names to detect symbol-header lines
f_isKnownTicker(rowUp) =>
    (str.contains(rowUp, "GOLD")   or str.contains(rowUp, "NQ")     or
     str.contains(rowUp, "EURUSD") or str.contains(rowUp, "GBPUSD") or
     str.contains(rowUp, "USDJPY") or str.contains(rowUp, "AUDUSD") or
     str.contains(rowUp, "NZDUSD") or str.contains(rowUp, "USDCAD") or
     str.contains(rowUp, "USDCHF") or str.contains(rowUp, "GBPJPY") or
     str.contains(rowUp, "EURGBP") or str.contains(rowUp, "EURJPY") or
     str.contains(rowUp, "EURCHF") or str.contains(rowUp, "GBPCHF") or
     str.contains(rowUp, "AUDJPY") or str.contains(rowUp, "CADJPY") or
     str.contains(rowUp, "SPX500") or str.contains(rowUp, "DE30")   or
     str.contains(rowUp, "UK100")  or str.contains(rowUp, "US2000") or
     str.contains(rowUp, "US30"))

var float[]  czPrices = array.new_float()
var int[]    czCounts = array.new_int()
var string[] czTypes  = array.new_string()

if barstate.isfirst
    sym   = f_normaliseTicker(syminfo.ticker, goldChart, nqChart, spxChart, de30Chart, uk100Chart, us30Chart, us2kChart)
    symUp = str.upper(sym)
    rows  = str.split(czText, "\n")
    n     = array.size(rows)

    bool inCZSection = false
    bool inSymBlock  = false

    if n > 0
        for i = 0 to n - 1
            rawRow = str.trim(array.get(rows, i))
            if str.length(rawRow) < 2
                if inSymBlock
                    inSymBlock := false
                continue
            rowUp = str.upper(rawRow)

            if str.contains(rowUp, "CONFLUENCE ZONES")
                inCZSection := true
                inSymBlock  := false
                continue

            if not inCZSection
                continue

            if str.contains(rowUp, "GENERATED:") or str.contains(rowUp, "CONFIG:")
                continue

            if not str.startswith(rawRow, "CZ ") and f_isKnownTicker(rowUp) and str.length(rawRow) <= 12
                inSymBlock := str.contains(rowUp, symUp)
                continue

            if inSymBlock and str.startswith(rawRow, "CZ ")
                parts = str.split(rawRow, " : ")
                if array.size(parts) == 2
                    priceStr   = str.trim(str.replace_all(array.get(parts, 0), "CZ ", ""))
                    countTypes = str.trim(array.get(parts, 1))
                    ctParts    = str.split(countTypes, " ")
                    if array.size(ctParts) >= 2
                        price = str.tonumber(priceStr)
                        cnt   = int(str.tonumber(str.trim(array.get(ctParts, 0))))
                        types = str.trim(array.get(ctParts, 1))
                        if not na(price) and not na(cnt) and price > 0
                            array.push(czPrices, price)
                            array.push(czCounts, cnt)
                            array.push(czTypes,  types)

// =====================================================
// DAILY BAR ACCUMULATION (runs every bar)
// Builds a rolling array of each complete day's H/L.
// Last element = current (possibly incomplete) day.
// =====================================================

var float[] _dH = array.new_float(0)
var float[] _dL = array.new_float(0)

bool _newDay = timeframe.change("D") or barstate.isfirst

if _newDay
    array.push(_dH, high)
    array.push(_dL, low)
    int _maxKeep = npoc_lookback + 2
    while array.size(_dH) > _maxKeep
        array.shift(_dH)
        array.shift(_dL)
else
    int _nd = array.size(_dH)
    if _nd > 0
        array.set(_dH, _nd - 1, math.max(array.get(_dH, _nd - 1), high))
        array.set(_dL, _nd - 1, math.min(array.get(_dL, _nd - 1), low))

// =====================================================
// DRAW ZONES + ALERT
// =====================================================

var line[]  czLines    = array.new_line()
var label[] czLabels   = array.new_label()
var line[]  pocLines   = array.new_line()
var label[] pocLabels  = array.new_label()
var line[]  npocLines  = array.new_line()
var label[] npocLabels = array.new_label()

f_zoneColour(cnt) =>
    cnt >= 4 ? col_4plus : cnt == 3 ? col_3 : col_2

if barstate.islast
    // ── Cleanup — CZ ──────────────────────────────────────────────────────────
    int _nl = array.size(czLines)
    if _nl > 0
        for i = 0 to _nl - 1
            line.delete(array.get(czLines, i))
    int _nlab = array.size(czLabels)
    if _nlab > 0
        for i = 0 to _nlab - 1
            label.delete(array.get(czLabels, i))
    array.clear(czLines)
    array.clear(czLabels)

    // ── Cleanup — POC ─────────────────────────────────────────────────────────
    int _npl = array.size(pocLines)
    if _npl > 0
        for i = 0 to _npl - 1
            line.delete(array.get(pocLines, i))
    array.clear(pocLines)
    int _npll = array.size(pocLabels)
    if _npll > 0
        for i = 0 to _npll - 1
            label.delete(array.get(pocLabels, i))
    array.clear(pocLabels)

    // ── Cleanup — NPOC ────────────────────────────────────────────────────────
    int _nnl = array.size(npocLines)
    if _nnl > 0
        for i = 0 to _nnl - 1
            line.delete(array.get(npocLines, i))
    array.clear(npocLines)
    int _nnll = array.size(npocLabels)
    if _nnll > 0
        for i = 0 to _nnll - 1
            label.delete(array.get(npocLabels, i))
    array.clear(npocLabels)

    sym    = f_normaliseTicker(syminfo.ticker, goldChart, nqChart, spxChart, de30Chart, uk100Chart, us30Chart, us2kChart)
    pip    = f_pipSize(sym)
    nZones = array.size(czPrices)

    // ── Draw CZ zones from paste block ────────────────────────────────────────
    if nZones > 0
        for i = 0 to nZones - 1
            zPrice     = array.get(czPrices, i)
            zCount     = array.get(czCounts, i)
            zTypes     = array.get(czTypes,  i)
            isAnchored = str.contains(zTypes, "vol_m") or str.contains(zTypes, "vol_75")

            // Skip unanchored zones entirely when filter is on
            if req_anchor and not isAnchored
                continue

            zCol     = f_zoneColour(zCount)
            // Unanchored zones drawn dimmed (70% transparent) unless user disabled dimming
            zColDraw = (not isAnchored and dim_unanchor) ? color.new(zCol, 70) : zCol
            zExt     = alert_extend_right ? extend.right : extend.none

            ln = line.new(bar_index - 1, zPrice, bar_index + 3, zPrice,
                 color=zColDraw, width=zone_width, style=line.style_solid, extend=zExt)
            array.push(czLines, ln)

            if show_label
                string lText = str.tostring(zCount) + "L"
                if show_types
                    lText := lText + "  " + zTypes
                lb = label.new(bar_index + 4, zPrice, lText,
                     style=label.style_label_left,
                     color=color.new(zColDraw, 75), textcolor=zColDraw,
                     size=size.small)
                array.push(czLabels, lb)

    // ── Draw POC / NPOC from daily bars ───────────────────────────────────────
    nDays = array.size(_dH)
    if nDays >= 2
        lastComplete = nDays - 2  // last element is current incomplete day; skip it

        // POC — last poc_days complete daily midpoints
        if show_poc
            pocStart = math.max(0, lastComplete - poc_days + 1)
            for d = pocStart to lastComplete
                ph = array.get(_dH, d)
                pl = array.get(_dL, d)
                if not na(ph) and not na(pl)
                    mid = (ph + pl) / 2.0
                    ln = line.new(bar_index - 1, mid, bar_index, mid,
                         color=col_poc, width=poc_lw,
                         style=line.style_dotted, extend=extend.right)
                    array.push(pocLines, ln)
                    if show_label
                        lb = label.new(bar_index + 4, mid, "POC",
                             style=label.style_label_left,
                             color=color.new(col_poc, 75), textcolor=col_poc, size=size.small)
                        array.push(pocLabels, lb)

        // NPOC — scan full lookback; keep midpoints not visited since formation
        if show_npoc
            for d = 0 to lastComplete
                ph = array.get(_dH, d)
                pl = array.get(_dL, d)
                if not na(ph) and not na(pl)
                    mid = (ph + pl) / 2.0
                    isNaked = true
                    // Any day after this one (including today's partial bar) trades through → no longer naked
                    for j = d + 1 to nDays - 1
                        jh = array.get(_dH, j)
                        jl = array.get(_dL, j)
                        if not na(jh) and not na(jl)
                            if jh >= mid and jl <= mid
                                isNaked := false
                                break
                    if isNaked
                        ln = line.new(bar_index - 1, mid, bar_index, mid,
                             color=col_npoc, width=poc_lw,
                             style=line.style_dashed, extend=extend.right)
                        array.push(npocLines, ln)
                        if show_label
                            lb = label.new(bar_index + 4, mid, "NPOC",
                                 style=label.style_label_left,
                                 color=color.new(col_npoc, 75), textcolor=col_npoc, size=size.small)
                            array.push(npocLabels, lb)

// =====================================================
// PROXIMITY ALERT (CZ paste zones only)
// =====================================================

f_anyZoneNear() =>
    sym  = f_normaliseTicker(syminfo.ticker, goldChart, nqChart, spxChart, de30Chart, uk100Chart, us30Chart, us2kChart)
    pip  = f_pipSize(sym)
    dist = alert_pips * pip
    near = false
    n    = array.size(czPrices)
    if n > 0
        for i = 0 to n - 1
            if array.get(czCounts, i) >= alert_min_count
                zTyp      = array.get(czTypes, i)
                isAnch    = str.contains(zTyp, "vol_m") or str.contains(zTyp, "vol_75")
                // Only alert on anchored zones when filter is on; always alert otherwise
                if not req_anchor or isAnch
                    if math.abs(close - array.get(czPrices, i)) <= dist
                        near := true
                        break
    near

bool nearZone = f_anyZoneNear()

if nearZone and not nearZone[1]
    alert("CZ: price approaching confluence zone on " + syminfo.ticker, alert.freq_once_per_bar_close)

alertcondition(nearZone, title="CZ Proximity Alert",
     message="Price within {{plot_0}} pips of a confluence zone on {{ticker}}")

// Hidden plot so alertcondition message can reference {{plot_0}}
plot(nearZone ? close : na, display=display.none, title="_cz_alert_ref")

// =====================================================
// SUMMARY TABLE (CZ paste zones)
// =====================================================

var table czTable = na

if show_table and barstate.islast
    table.delete(czTable)
    nZones = array.size(czPrices)
    if nZones > 0
        // Count how many zones will actually be displayed (respects anchor filter)
        int nVisible = 0
        for i = 0 to nZones - 1
            zTyp = array.get(czTypes, i)
            if not req_anchor or str.contains(zTyp, "vol_m") or str.contains(zTyp, "vol_75")
                nVisible += 1

        if nVisible > 0
            czTable := table.new(position.top_left, 3, nVisible + 1,
                 bgcolor=color.new(color.black, 60),
                 border_width=1, border_color=color.new(color.gray, 60),
                 frame_width=1,  frame_color=color.new(color.gray, 50))

            table.cell(czTable, 0, 0, "Price",  text_color=color.new(color.white, 40), text_size=size.tiny, bgcolor=color.new(color.gray, 80))
            table.cell(czTable, 1, 0, "Layers", text_color=color.new(color.white, 40), text_size=size.tiny, bgcolor=color.new(color.gray, 80))
            table.cell(czTable, 2, 0, "Types",  text_color=color.new(color.white, 40), text_size=size.tiny, bgcolor=color.new(color.gray, 80))

            sym  = f_normaliseTicker(syminfo.ticker, goldChart, nqChart, spxChart, de30Chart, uk100Chart, us30Chart, us2kChart)
            pip  = f_pipSize(sym)

            int row = 0
            for i = 0 to nZones - 1
                zPrice     = array.get(czPrices, i)
                zCount     = array.get(czCounts, i)
                zTypes     = array.get(czTypes,  i)
                isAnchored = str.contains(zTypes, "vol_m") or str.contains(zTypes, "vol_75")

                if req_anchor and not isAnchored
                    continue

                row += 1
                zCol    = f_zoneColour(zCount)
                zColTbl = (not isAnchored and dim_unanchor) ? color.new(zCol, 60) : zCol
                pipDist = math.round(math.abs(close - zPrice) / pip, 1)
                bg      = color.new(zColTbl, 80)

                table.cell(czTable, 0, row, str.tostring(zPrice),  text_color=zColTbl, text_size=size.tiny, bgcolor=bg)
                table.cell(czTable, 1, row, str.tostring(zCount),  text_color=zColTbl, text_size=size.tiny, bgcolor=bg)
                table.cell(czTable, 2, row, str.tostring(pipDist) + "p " + zTypes, text_color=zColTbl, text_size=size.tiny, bgcolor=bg)
