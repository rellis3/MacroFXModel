# Copy this to .env and fill in your details.
# The .env file must live inside backtestSystem/ (same folder as main.py).

# ── Option A: pull credentials from the dashboard (recommended) ───────────────
# Set this and leave the MT5_* vars below blank.
# Credentials are then managed from the Bot Config page → "MT5 Credentials — Backtest Bot".
DASHBOARD_URL=https://your-railway-app.railway.app

# ── Option B: set credentials directly in .env ────────────────────────────────
# Used as fallback when DASHBOARD_URL is not set or KV fetch fails.
MT5_ACCOUNT=12345678
MT5_PASSWORD=your_password_here
MT5_SERVER=ICMarketsEU-Demo

# Optional: full path to terminal64.exe if MT5 isn't in the default location.
# Leave blank to let the library find it automatically.
MT5_PATH=
