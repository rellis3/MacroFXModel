//@version=6
indicator("C.og - Volatility Overlay v3 (Sessions)", overlay=true, max_labels_count=500, max_lines_count=500)

// =====================================================
// INPUTS — TICKER MAPPING
// =====================================================

goldChart = input.string("XAUUSD", "Gold — chart ticker",  tooltip="e.g. XAUUSD, GC1!, GOLD")
nqChart    = input.string("NQ1!",      "NQ — chart ticker",     tooltip="e.g. NQ1!, NAS100USD, US100")
spxChart   = input.string("SPX500USD", "SPX500 — chart ticker", tooltip="e.g. SPX500USD, US500, SP1!")
de30Chart  = input.string("GER40",     "DE30 — chart ticker",   tooltip="e.g. GER40, GER30, DE30EUR, FDAX1!")
uk100Chart = input.string("UK100GBP",  "UK100 — chart ticker",  tooltip="e.g. UK100GBP, Z1!, FTSE100")
us30Chart  = input.string("US30USD",   "US30 — chart ticker",   tooltip="e.g. US30USD, DJIA, YM1!")
us2kChart  = input.string("US2000USD", "US2000 — chart ticker", tooltip="e.g. US2000USD, RTY1!, RUT")

// =====================================================
// INPUT — PASTE VOLATILITY BLOCK (v3 — includes SESSION STATS)
// =====================================================
// Use the ⬇ V+S export button on the vol-forecast dashboard.
// The SESSION STATS section enables the Asia/London projection lines.
// Pasting the plain ⬇ Export (no session stats) disables session lines
// but keeps all standard vol lines + grey Day H/L lines.

volText = input.text_area(
     title  = "Paste V+S Block (Vol + Session Stats)",
     defval =
"──── GOLD ─────────────────────\n" +
"Volatility (annualized) : 26.76%\n" +
"High to Low range  : 2.74% median · 3.26% 75th Percentile\n" +
"Open to Close move : 1.30% median · 2.17% 75th Percentile\n" +
"──── EURUSD ─────────────────\n" +
"Volatility (annualized) : 5.47%\n" +
"High to Low range  : 0.52% median · 0.64% 75th Percentile\n" +
"Open to Close move : 0.23% median · 0.41% 75th Percentile\n" +
"──── NQ ─────────────────────\n" +
"Volatility (annualized) : 23.34%\n" +
"High to Low range  : 2.28% median · 2.85% 75th Percentile\n" +
"Open to Close move : 1.06% median · 1.87% 75th Percentile"
)

// =====================================================
// STYLE INPUTS — STANDARD
// =====================================================

col_75      = input.color(color.new(color.orange, 0),  "75th Percentile Colour")
col_med     = input.color(color.new(color.orange, 55), "Median Colour")
col_oc_75   = input.color(color.new(color.aqua,   0),  "OC 75th Colour")
col_oc_med  = input.color(color.new(color.aqua,   55), "OC Median Colour")
col_open    = input.color(color.new(color.white,  55), "Day Open Colour")
openSource  = input.string("London Midnight (00:00)", "Session Open Source",
     options=["London Midnight (00:00)", "Pre-Session (23:00 prev night)"],
     tooltip="Midnight: standard FX day open at 00:00 London time.\nPre-Session 23:00: day/open resets at 23:00 London (post-market session open — recommended for indices like SPX500, DE30, UK100, US30, US2000).\nChanging this option redraws all levels from the new open time.")
show_table  = input.bool(true,  "Show Live Stats Panel")
show_labels = input.bool(true,  "Show Line Labels")

// =====================================================
// STYLE INPUTS — SESSION LINES
// =====================================================

show_sessions  = input.bool(true,  "Show Session Lines (requires V+S paste)")
col_day_hl     = input.color(color.new(color.gray,  30), "Day High/Low Colour")
col_asia       = input.color(color.new(color.blue,  0),  "Asia Session Colour")
col_asia_med   = input.color(color.new(color.blue,  55), "Asia Median Colour")
col_london     = input.color(color.new(color.green, 0),  "London Extension Colour")

// =====================================================
// STYLE INPUTS — OH / OL + DRIFT
// =====================================================

show_oh_ol_drift = input.bool(false,  "Show OH/OL + Drift Lines",  group="OH/OL + Drift",
     tooltip="Draws Open-High (upside) and Open-Low (downside) band lines anchored at the daily open, plus a drift forecast arrow. Requires the v2 export block that contains Open High / Open Low / Drift lines.")
col_oh_75  = input.color(color.new(color.yellow,  0),  "OH 75th Colour",   group="OH/OL + Drift")
col_oh_med = input.color(color.new(color.yellow,  60), "OH Median Colour", group="OH/OL + Drift")
col_ol_75  = input.color(color.new(color.fuchsia, 0),  "OL 75th Colour",   group="OH/OL + Drift")
col_ol_med = input.color(color.new(color.fuchsia, 60), "OL Median Colour", group="OH/OL + Drift")

// =====================================================
// HELPERS (unchanged from v1)
// =====================================================

f_normaliseTicker(t, goldT, nqT, spxT, de30T, uk100T, us30T, us2kT) =>
    r = t
    if t == str.upper(goldT) or t == "XAUUSD" or t == "GOLD"
        r := "GOLD"
    else if t == str.upper(nqT) or t == "NQ1!" or t == "NQ" or t == "NASDAQ100"
        r := "NQ"
    else if t == str.upper(spxT) or t == "SPX500USD" or t == "US500" or t == "SP1!"
        r := "SPX500"
    else if t == str.upper(de30T) or t == "GER40" or t == "GER30" or t == "DE30EUR" or t == "FDAX1!"
        r := "DE30"
    else if t == str.upper(uk100T) or t == "UK100GBP" or t == "Z1!" or t == "FTSE100"
        r := "UK100"
    else if t == str.upper(us30T) or t == "US30USD" or t == "DJIA" or t == "YM1!"
        r := "US30"
    else if t == str.upper(us2kT) or t == "US2000USD" or t == "RTY1!" or t == "RUT"
        r := "US2000"
    r

f_collapseSpaces(s) =>
    r = s
    r := str.replace_all(r, "  ", " ")
    r := str.replace_all(r, "  ", " ")
    r := str.replace_all(r, "  ", " ")
    r

f_firstNumAfter(src, keyword) =>
    result = float(na)
    if str.contains(src, keyword)
        after = str.trim(array.get(str.split(src, keyword), 1))
        clean = str.replace_all(after, "%", " ")
        parts = str.split(clean, " ")
        for j = 0 to array.size(parts) - 1
            val = str.tonumber(str.trim(array.get(parts, j)))
            if not na(val) and na(result)
                result := val
    result

f_lastNumBefore(src, keyword) =>
    result = float(na)
    if str.contains(src, keyword)
        before = str.trim(array.get(str.split(src, keyword), 0))
        clean  = str.replace_all(before, "%", " ")
        parts  = str.split(clean, " ")
        sz     = array.size(parts)
        if sz > 0
            for j = 0 to sz - 1
                val = str.tonumber(str.trim(array.get(parts, sz - 1 - j)))
                if not na(val) and na(result)
                    result := val
    result

f_pct(price, ref) =>
    math.round((price - ref) / ref * 100, 2)

f_pctStr(v) =>
    (v >= 0 ? "+" : "") + str.tostring(v) + "%"

// Drift parser — handles +/- prefixed numbers that str.tonumber may not parse with "+"
f_parseDrift(src, keyword) =>
    result = float(na)
    if str.contains(src, keyword)
        after = str.trim(array.get(str.split(src, keyword), 1))
        parts = str.split(after, " ")
        for j = 0 to array.size(parts) - 1
            token   = str.trim(array.get(parts, j))
            stripped = str.length(token) > 1 and str.startswith(token, "+") ? str.substring(token, 1) : token
            val = str.tonumber(stripped)
            if not na(val) and na(result)
                result := val
    result

// =====================================================
// PARSE VOL DATA + SESSION STATS FROM PASTE
// =====================================================

var float vol_hl_med     = na
var float vol_hl_75      = na
var float vol_oc_med     = na
var float vol_oc_75      = na
// Open High (upside) / Open Low (downside) asymmetric bands
var float vol_oh_med     = na   // Open High median %
var float vol_oh_75      = na   // Open High 75th %
var float vol_ol_med     = na   // Open Low median %
var float vol_ol_75      = na   // Open Low 75th %
// Drift d=μ/σ
var float drift_val      = na
// Session H-L consumption %s (% of daily H-L — set only if SESSION STATS section found in paste)
var float asia_med_pct      = na
var float asia_75_pct       = na
var float london_med_pct    = na
var float london_75_pct     = na
// Session O-C move %s (% of daily H-L — present only when V+S block includes O-C lines)
var float asia_oc_med_pct   = na
var float asia_oc_75_pct    = na
var float london_oc_med_pct = na
var float london_oc_75_pct  = na

if barstate.isfirst
    sym   = f_normaliseTicker(syminfo.ticker, goldChart, nqChart, spxChart, de30Chart, uk100Chart, us30Chart, us2kChart)
    symUp = str.upper(sym)
    rows  = str.split(volText, "\n")
    n     = array.size(rows)

    bool insideVolBlock     = false
    bool inSessionSection   = false
    bool inSessionSymBlock  = false

    if n > 0
        for i = 0 to n - 1
            rowRaw = f_collapseSpaces(str.trim(array.get(rows, i)))
            if str.length(rowRaw) < 2
                continue
            rowUp = str.upper(rowRaw)

            // ── Detect SESSION STATS section ──────────────────────────────────
            if str.contains(rowUp, "SESSION STATS")
                inSessionSection  := true
                insideVolBlock    := false
                inSessionSymBlock := false
                continue

            // ── SESSION STATS parsing ─────────────────────────────────────────
            if inSessionSection
                isAsiaLine   = str.contains(rowUp, "ASIA RANGE")
                isLonLine    = str.contains(rowUp, "LONDON RANGE")
                isAsiaOCLine = str.contains(rowUp, "ASIA O-C")
                isLonOCLine  = str.contains(rowUp, "LONDON O-C")
                isDataLine2  = isAsiaLine or isLonLine or isAsiaOCLine or isLonOCLine or
                     str.contains(rowUp, "NY RANGE") or str.contains(rowUp, "NY O-C")

                // A new known-ticker header line resets the sym block
                isOtherTicker = (str.contains(rowUp, "GOLD")   or str.contains(rowUp, "NQ")     or
                     str.contains(rowUp, "EURUSD") or str.contains(rowUp, "GBPUSD") or
                     str.contains(rowUp, "USDJPY") or str.contains(rowUp, "AUDUSD") or
                     str.contains(rowUp, "NZDUSD") or str.contains(rowUp, "USDCAD") or
                     str.contains(rowUp, "USDCHF") or str.contains(rowUp, "GBPJPY") or
                     str.contains(rowUp, "EURGBP") or str.contains(rowUp, "EURJPY") or
                     str.contains(rowUp, "EURCHF") or str.contains(rowUp, "GBPCHF") or
                     str.contains(rowUp, "AUDJPY") or str.contains(rowUp, "CADJPY") or
                     str.contains(rowUp, "SPX500") or str.contains(rowUp, "DE30")   or
                     str.contains(rowUp, "UK100")  or str.contains(rowUp, "US2000") or
                     str.contains(rowUp, "US30")) and
                     not isDataLine2

                if isOtherTicker
                    inSessionSymBlock := str.contains(rowUp, symUp)
                if inSessionSymBlock and isAsiaLine
                    med = f_firstNumAfter(rowRaw, ": ")
                    p75 = f_lastNumBefore(rowRaw, "75th")
                    if not na(med) and na(asia_med_pct)
                        asia_med_pct := med
                    if not na(p75) and na(asia_75_pct)
                        asia_75_pct  := p75
                if inSessionSymBlock and isLonLine
                    med = f_firstNumAfter(rowRaw, ": ")
                    p75 = f_lastNumBefore(rowRaw, "75th")
                    if not na(med) and na(london_med_pct)
                        london_med_pct := med
                    if not na(p75) and na(london_75_pct)
                        london_75_pct  := p75
                if inSessionSymBlock and isAsiaOCLine
                    med = f_firstNumAfter(rowRaw, ": ")
                    p75 = f_lastNumBefore(rowRaw, "75th")
                    if not na(med) and na(asia_oc_med_pct)
                        asia_oc_med_pct := med
                    if not na(p75) and na(asia_oc_75_pct)
                        asia_oc_75_pct  := p75
                if inSessionSymBlock and isLonOCLine
                    med = f_firstNumAfter(rowRaw, ": ")
                    p75 = f_lastNumBefore(rowRaw, "75th")
                    if not na(med) and na(london_oc_med_pct)
                        london_oc_med_pct := med
                    if not na(p75) and na(london_oc_75_pct)
                        london_oc_75_pct  := p75
                continue

            // ── Standard vol block parsing ────────────────────────────────────
            isDataLine    = str.contains(rowUp, "RANGE") or str.contains(rowUp, "MOVE") or
                 str.contains(rowUp, "VOLATILITY") or str.contains(rowUp, "PERCENTILE") or
                 str.contains(rowUp, "OPEN HIGH") or str.contains(rowUp, "OPEN LOW") or
                 str.contains(rowUp, "DRIFT")
            isKnownTicker = str.contains(rowUp, "GOLD")   or str.contains(rowUp, "NQ")     or
                 str.contains(rowUp, "EURUSD") or str.contains(rowUp, "GBPUSD") or
                 str.contains(rowUp, "USDJPY") or str.contains(rowUp, "AUDUSD") or
                 str.contains(rowUp, "NZDUSD") or str.contains(rowUp, "USDCAD") or
                 str.contains(rowUp, "USDCHF") or str.contains(rowUp, "GBPJPY") or
                 str.contains(rowUp, "EURGBP") or str.contains(rowUp, "EURJPY") or
                 str.contains(rowUp, "EURCHF") or str.contains(rowUp, "GBPCHF") or
                 str.contains(rowUp, "AUDJPY") or str.contains(rowUp, "CADJPY") or
                 str.contains(rowUp, "SPX500") or str.contains(rowUp, "DE30")   or
                 str.contains(rowUp, "UK100")  or str.contains(rowUp, "US2000") or
                 str.contains(rowUp, "US30")

            if not isDataLine and isKnownTicker
                insideVolBlock := str.contains(rowUp, symUp)
            else if insideVolBlock and isDataLine
                if str.contains(rowUp, "RANGE")
                    med = f_firstNumAfter(rowRaw, "range : ")
                    if not na(med) and na(vol_hl_med)
                        vol_hl_med := med
                    p75 = f_lastNumBefore(rowRaw, "75th")
                    if not na(p75) and na(vol_hl_75)
                        vol_hl_75 := p75
                if str.contains(rowUp, "MOVE")
                    med = f_firstNumAfter(rowRaw, "move : ")
                    if not na(med) and na(vol_oc_med)
                        vol_oc_med := med
                    p75 = f_lastNumBefore(rowRaw, "75th")
                    if not na(p75) and na(vol_oc_75)
                        vol_oc_75 := p75
                if str.contains(rowUp, "OPEN HIGH")
                    med = f_firstNumAfter(rowRaw, ": ")
                    p75 = f_lastNumBefore(rowRaw, "75th")
                    if not na(med) and na(vol_oh_med)
                        vol_oh_med := med
                    if not na(p75) and na(vol_oh_75)
                        vol_oh_75 := p75
                if str.contains(rowUp, "OPEN LOW")
                    med = f_firstNumAfter(rowRaw, ": ")
                    p75 = f_lastNumBefore(rowRaw, "75th")
                    if not na(med) and na(vol_ol_med)
                        vol_ol_med := med
                    if not na(p75) and na(vol_ol_75)
                        vol_ol_75 := p75
                if str.contains(rowUp, "DRIFT")
                    d = f_parseDrift(rowRaw, ": ")
                    if not na(d) and na(drift_val)
                        drift_val := d

// =====================================================
// DAILY TRACKING
// =====================================================

use23Open   = openSource == "Pre-Session (23:00 prev night)"
londonHour  = hour(time, "Europe/London")
prevLonHour = barstate.isfirst ? -1 : hour(time[1], "Europe/London")
newDayMid   = ta.change(dayofmonth(time, "Europe/London")) != 0
newDay23    = londonHour == 23 and prevLonHour != 23
newDay      = use23Open ? newDay23 : newDayMid

var int dayStartBar  = 0
var int dayStartTime = 0
if newDay or barstate.isfirst
    dayStartBar  := bar_index
    dayStartTime := time

var float dayOpen = na
var float dayHigh = na
var float dayLow  = na

if newDay or barstate.isfirst
    dayOpen := open
    dayHigh := high
    dayLow  := low
else
    dayHigh := math.max(dayHigh, high)
    dayLow  := math.min(dayLow,  low)

liveHL_pct = math.round((dayHigh - dayLow) / dayOpen * 100, 2)

// =====================================================
// ASIA SESSION TRACKING
// =====================================================
// Asia = 00:00–06:00 Europe/London

inAsia     = londonHour >= 0 and londonHour < 6

var float asiaHigh     = na
var float asiaLow      = na
var float asiaClose    = na   // close of the last bar before 06:00 London = London session open reference
var bool  asiaComplete = false

if newDay or barstate.isfirst
    asiaHigh     := na
    asiaLow      := na
    asiaClose    := na
    asiaComplete := false

if inAsia
    asiaHigh  := na(asiaHigh) ? high : math.max(asiaHigh, high)
    asiaLow   := na(asiaLow)  ? low  : math.min(asiaLow,  low)
    asiaClose := close        // updated each bar; holds the Asia session close after session ends
else if not na(asiaHigh)
    asiaComplete := true

// =====================================================
// PRICE LEVELS — STANDARD (unchanged from v1)
// =====================================================

pH_med = not na(vol_hl_med) ? dayLow  * (1 + vol_hl_med / 100) : na
pH_75  = not na(vol_hl_75)  ? dayLow  * (1 + vol_hl_75  / 100) : na
pL_med = not na(vol_hl_med) ? dayHigh * (1 - vol_hl_med / 100) : na
pL_75  = not na(vol_hl_75)  ? dayHigh * (1 - vol_hl_75  / 100) : na

oc_up_med = not na(vol_oc_med) ? dayOpen * (1 + vol_oc_med / 100) : na
oc_dn_med = not na(vol_oc_med) ? dayOpen * (1 - vol_oc_med / 100) : na
oc_up_75  = not na(vol_oc_75)  ? dayOpen * (1 + vol_oc_75  / 100) : na
oc_dn_75  = not na(vol_oc_75)  ? dayOpen * (1 - vol_oc_75  / 100) : na

// =====================================================
// PRICE LEVELS — OH / OL (anchored at day open, asymmetric)
// =====================================================

oh_up_75  = not na(vol_oh_75)  ? dayOpen * (1 + vol_oh_75  / 100) : na
oh_up_med = not na(vol_oh_med) ? dayOpen * (1 + vol_oh_med / 100) : na
ol_dn_75  = not na(vol_ol_75)  ? dayOpen * (1 - vol_ol_75  / 100) : na
ol_dn_med = not na(vol_ol_med) ? dayOpen * (1 - vol_ol_med / 100) : na

// =====================================================
// PRICE LEVELS — SESSION PROJECTIONS
// =====================================================
// Daily range in price points from the open
dailyPts_med = not na(vol_hl_med) ? dayOpen * vol_hl_med / 100 : na
dailyPts_75  = not na(vol_hl_75)  ? dayOpen * vol_hl_75  / 100 : na

// Asia projected range (during Asia: show where session might reach)
asiaRangePts_med = not na(dailyPts_med) and not na(asia_med_pct) ? dailyPts_med * asia_med_pct / 100 : na
asiaRangePts_75  = not na(dailyPts_75)  and not na(asia_75_pct)  ? dailyPts_75  * asia_75_pct  / 100 : na

// Anchor projections from the live extremes: once Asia High is known, project the
// Low from it (and vice versa), so the line always sits exactly one Asia-range away.
// Fall back to dayOpen before any extreme is established.
asiaHRef = na(asiaHigh) ? dayOpen : asiaHigh
asiaLRef = na(asiaLow)  ? dayOpen : asiaLow

asiaProj_L_med = not na(asiaRangePts_med) ? asiaHRef - asiaRangePts_med : na
asiaProj_L_75  = not na(asiaRangePts_75)  ? asiaHRef - asiaRangePts_75  : na
asiaProj_H_med = not na(asiaRangePts_med) ? asiaLRef + asiaRangePts_med : na
asiaProj_H_75  = not na(asiaRangePts_75)  ? asiaLRef + asiaRangePts_75  : na

// London extension — remaining daily range budget from Asia extremes
asiaActualPts     = not na(asiaHigh) and not na(asiaLow) ? asiaHigh - asiaLow : float(na)
remainingPts_med  = not na(dailyPts_med) and not na(asiaActualPts) ? math.max(0, dailyPts_med - asiaActualPts) : na
remainingPts_75   = not na(dailyPts_75)  and not na(asiaActualPts) ? math.max(0, dailyPts_75  - asiaActualPts) : na

lonExt_H_75  = not na(asiaHigh) and not na(remainingPts_75)  ? asiaHigh + remainingPts_75  : na
lonExt_L_75  = not na(asiaLow)  and not na(remainingPts_75)  ? asiaLow  - remainingPts_75  : na
lonExt_H_med = not na(asiaHigh) and not na(remainingPts_med) ? asiaHigh + remainingPts_med : na
lonExt_L_med = not na(asiaLow)  and not na(remainingPts_med) ? asiaLow  - remainingPts_med : na

// London O-C projections — from Asia close, using session O-C % of daily range
// Answers: "from where Asia left off, where might London close?"
lonOC_pts_med = not na(dailyPts_med) and not na(london_oc_med_pct) ? dailyPts_med * london_oc_med_pct / 100 : na
lonOC_pts_75  = not na(dailyPts_75)  and not na(london_oc_75_pct)  ? dailyPts_75  * london_oc_75_pct  / 100 : na

lonOC_H_med = not na(asiaClose) and not na(lonOC_pts_med) ? asiaClose + lonOC_pts_med : na
lonOC_L_med = not na(asiaClose) and not na(lonOC_pts_med) ? asiaClose - lonOC_pts_med : na
lonOC_H_75  = not na(asiaClose) and not na(lonOC_pts_75)  ? asiaClose + lonOC_pts_75  : na
lonOC_L_75  = not na(asiaClose) and not na(lonOC_pts_75)  ? asiaClose - lonOC_pts_75  : na

// Gate: session lines only show if session stats were found in the paste
sessionStatsFound = not na(asia_med_pct) and not na(london_med_pct)

// =====================================================
// STATIC PLOTS — OC + OPEN (unchanged from v1)
// =====================================================

plot(dayOpen,    "Day Open",     color=col_open,   linewidth=1, style=plot.style_stepline_diamond)
plot(oc_up_75,   "Close 75 Up",  color=col_oc_75,  linewidth=2, style=plot.style_stepline)
plot(oc_dn_75,   "Close 75 Dn",  color=col_oc_75,  linewidth=2, style=plot.style_stepline)
plot(oc_up_med,  "Close Med Up", color=col_oc_med, linewidth=1, style=plot.style_stepline)
plot(oc_dn_med,  "Close Med Dn", color=col_oc_med, linewidth=1, style=plot.style_stepline)

// =====================================================
// STATIC PLOTS — OH / OL (asymmetric open-anchored bands)
// =====================================================

plot(show_oh_ol_drift ? oh_up_75  : na, "OH 75th Up",  color=col_oh_75,  linewidth=2, style=plot.style_stepline)
plot(show_oh_ol_drift ? oh_up_med : na, "OH Med Up",   color=col_oh_med, linewidth=1, style=plot.style_stepline)
plot(show_oh_ol_drift ? ol_dn_75  : na, "OL 75th Dn",  color=col_ol_75,  linewidth=2, style=plot.style_stepline)
plot(show_oh_ol_drift ? ol_dn_med : na, "OL Med Dn",   color=col_ol_med, linewidth=1, style=plot.style_stepline)

// =====================================================
// DYNAMIC LINES + LABELS
// =====================================================

// — Standard projected H/L (unchanged from v1) —
var line  ln_pH_75  = na
var line  ln_pH_med = na
var line  ln_pL_75  = na
var line  ln_pL_med = na
var label lb_pH_75  = na
var label lb_pH_med = na
var label lb_pL_75  = na
var label lb_pL_med = na
var label lb_oc_up_75  = na
var label lb_oc_dn_75  = na
var label lb_oc_up_med = na
var label lb_oc_dn_med = na
var label lb_open      = na

// — Day High / Day Low (grey, always shown) —
var line  ln_dayH = na
var line  ln_dayL = na
var label lb_dayH = na
var label lb_dayL = na

// — Asia projection lines (blue, shown during Asia when session stats found) —
var line  ln_ap_H_75  = na
var line  ln_ap_H_med = na
var line  ln_ap_L_75  = na
var line  ln_ap_L_med = na
var label lb_ap_H_75  = na
var label lb_ap_H_med = na
var label lb_ap_L_75  = na
var label lb_ap_L_med = na

// — London extension lines (green, shown after Asia when session stats found) —
var line  ln_aH     = na   // actual Asia High marker
var line  ln_aL     = na   // actual Asia Low marker
var line  ln_lE_H75 = na   // London Ext from Asia High (75th)
var line  ln_lE_L75 = na   // London Ext from Asia Low (75th)
var line  ln_lE_Hmd = na   // London Ext from Asia High (med)
var line  ln_lE_Lmd = na   // London Ext from Asia Low (med)
var label lb_aH     = na
var label lb_aL     = na
var label lb_lE_H75 = na
var label lb_lE_L75 = na

// — London O-C targets from Asia close (teal, shown after Asia) —
var line  ln_lOC_H75 = na
var line  ln_lOC_L75 = na
var line  ln_lOC_Hmd = na
var line  ln_lOC_Lmd = na
var label lb_lOC_H75 = na
var label lb_lOC_L75 = na

// — OH/OL labels + drift forecast arrow —
var label lb_oh_up_75  = na
var label lb_oh_up_med = na
var label lb_ol_dn_75  = na
var label lb_ol_dn_med = na
var line  ln_drift     = na
var label lb_drift     = na

if barstate.islast
    // ── cleanup all ──────────────────────────────────────────────────────────
    line.delete(ln_pH_75)
    line.delete(ln_pH_med)
    line.delete(ln_pL_75)
    line.delete(ln_pL_med)
    label.delete(lb_pH_75)
    label.delete(lb_pH_med)
    label.delete(lb_pL_75)
    label.delete(lb_pL_med)
    label.delete(lb_oc_up_75)
    label.delete(lb_oc_dn_75)
    label.delete(lb_oc_up_med)
    label.delete(lb_oc_dn_med)
    label.delete(lb_open)

    line.delete(ln_dayH)
    line.delete(ln_dayL)
    label.delete(lb_dayH)
    label.delete(lb_dayL)

    line.delete(ln_ap_H_75)
    line.delete(ln_ap_H_med)
    line.delete(ln_ap_L_75)
    line.delete(ln_ap_L_med)
    label.delete(lb_ap_H_75)
    label.delete(lb_ap_H_med)
    label.delete(lb_ap_L_75)
    label.delete(lb_ap_L_med)

    line.delete(ln_aH)
    line.delete(ln_aL)
    line.delete(ln_lE_H75)
    line.delete(ln_lE_L75)
    line.delete(ln_lE_Hmd)
    line.delete(ln_lE_Lmd)
    label.delete(lb_aH)
    label.delete(lb_aL)
    label.delete(lb_lE_H75)
    label.delete(lb_lE_L75)
    line.delete(ln_lOC_H75)
    line.delete(ln_lOC_L75)
    line.delete(ln_lOC_Hmd)
    line.delete(ln_lOC_Lmd)
    label.delete(lb_lOC_H75)
    label.delete(lb_lOC_L75)

    label.delete(lb_oh_up_75)
    label.delete(lb_oh_up_med)
    label.delete(lb_ol_dn_75)
    label.delete(lb_ol_dn_med)
    line.delete(ln_drift)
    label.delete(lb_drift)

    x1 = dayStartTime
    x2 = time

    // ── Day High / Day Low — grey, always shown ───────────────────────────────
    ln_dayH := line.new(x1, dayHigh, x2, dayHigh,
         color=col_day_hl, width=1, style=line.style_dashed,
         xloc=xloc.bar_time, extend=extend.right)
    ln_dayL := line.new(x1, dayLow, x2, dayLow,
         color=col_day_hl, width=1, style=line.style_dashed,
         xloc=xloc.bar_time, extend=extend.right)
    if show_labels
        lb_dayH := label.new(bar_index + 2, dayHigh, "Day High",
             style=label.style_label_left, color=color.new(col_day_hl, 70),
             textcolor=col_day_hl, size=size.small)
        lb_dayL := label.new(bar_index + 2, dayLow, "Day Low",
             style=label.style_label_left, color=color.new(col_day_hl, 70),
             textcolor=col_day_hl, size=size.small)

    // ── Standard projected H/L (unchanged from v1) ───────────────────────────
    if not na(pH_75)
        ln_pH_75 := line.new(x1, pH_75, x2, pH_75,
             color=col_75, width=2, xloc=xloc.bar_time, extend=extend.none)
        if show_labels
            hPct  = f_pctStr(f_pct(pH_75, dayLow))
            dMed  = f_pctStr(math.round(vol_hl_med - liveHL_pct, 2))
            d75   = f_pctStr(math.round(vol_hl_75  - liveHL_pct, 2))
            lb_pH_75 := label.new(bar_index + 2, pH_75,
                 "Proj H 75p  " + hPct + "\nΔMed " + dMed + "  Δ75p " + d75,
                 style=label.style_label_left, color=color.new(col_75, 70),
                 textcolor=color.white, size=size.small)

    if not na(pH_med)
        ln_pH_med := line.new(x1, pH_med, x2, pH_med,
             color=col_med, width=1, xloc=xloc.bar_time, extend=extend.none)
        if show_labels
            lb_pH_med := label.new(bar_index + 2, pH_med,
                 "Proj H med  " + f_pctStr(f_pct(pH_med, dayLow)),
                 style=label.style_label_left, color=color.new(col_med, 70),
                 textcolor=color.white, size=size.small)

    if not na(pL_75)
        ln_pL_75 := line.new(x1, pL_75, x2, pL_75,
             color=col_75, width=2, xloc=xloc.bar_time, extend=extend.none)
        if show_labels
            lPct  = f_pctStr(f_pct(pL_75, dayHigh))
            dMed  = f_pctStr(math.round(vol_hl_med - liveHL_pct, 2))
            d75   = f_pctStr(math.round(vol_hl_75  - liveHL_pct, 2))
            lb_pL_75 := label.new(bar_index + 2, pL_75,
                 "Proj L 75p  " + lPct + "\nΔMed " + dMed + "  Δ75p " + d75,
                 style=label.style_label_left, color=color.new(col_75, 70),
                 textcolor=color.white, size=size.small)

    if not na(pL_med)
        ln_pL_med := line.new(x1, pL_med, x2, pL_med,
             color=col_med, width=1, xloc=xloc.bar_time, extend=extend.none)
        if show_labels
            lb_pL_med := label.new(bar_index + 2, pL_med,
                 "Proj L med  " + f_pctStr(f_pct(pL_med, dayHigh)),
                 style=label.style_label_left, color=color.new(col_med, 70),
                 textcolor=color.white, size=size.small)

    if show_labels
        if not na(oc_up_75)
            lb_oc_up_75 := label.new(bar_index + 2, oc_up_75,
                 "Close 75p  " + f_pctStr(f_pct(oc_up_75, dayOpen)),
                 style=label.style_label_left, color=color.new(col_oc_75, 70),
                 textcolor=color.white, size=size.small)
        if not na(oc_dn_75)
            lb_oc_dn_75 := label.new(bar_index + 2, oc_dn_75,
                 "Close 75p  " + f_pctStr(f_pct(oc_dn_75, dayOpen)),
                 style=label.style_label_left, color=color.new(col_oc_75, 70),
                 textcolor=color.white, size=size.small)
        if not na(oc_up_med)
            lb_oc_up_med := label.new(bar_index + 2, oc_up_med,
                 "Close Med  " + f_pctStr(f_pct(oc_up_med, dayOpen)),
                 style=label.style_label_left, color=color.new(col_oc_med, 70),
                 textcolor=color.white, size=size.small)
        if not na(oc_dn_med)
            lb_oc_dn_med := label.new(bar_index + 2, oc_dn_med,
                 "Close Med  " + f_pctStr(f_pct(oc_dn_med, dayOpen)),
                 style=label.style_label_left, color=color.new(col_oc_med, 70),
                 textcolor=color.white, size=size.small)
        lb_open := label.new(bar_index + 2, dayOpen,
                 "Open",
                 style=label.style_label_left, color=color.new(color.white, 75),
                 textcolor=color.white, size=size.small)

    // ── Session lines — only if toggle on AND stats found in paste ────────────
    if show_sessions and sessionStatsFound

        // Asia projection lines — shown always; dulled to ghost once Asia closes
        apLineCol    = asiaComplete ? color.new(col_asia,     75) : col_asia
        apMedLineCol = asiaComplete ? color.new(col_asia_med, 75) : col_asia_med
        apLbBg       = asiaComplete ? color.new(col_asia,     88) : color.new(col_asia,     70)
        apMedLbBg    = asiaComplete ? color.new(col_asia_med, 88) : color.new(col_asia_med, 70)
        apTxt        = asiaComplete ? color.new(color.white,  75) : color.white
        apStyle      = asiaComplete ? line.style_dotted           : line.style_dashed

        // Proj H is asiaLow + range; Proj L is asiaHigh - range.
        // Labels show % from the anchoring extreme (not from open).
        if not na(asiaProj_H_75)
            ln_ap_H_75 := line.new(x1, asiaProj_H_75, x2, asiaProj_H_75,
                 color=apLineCol, width=2, style=apStyle,
                 xloc=xloc.bar_time, extend=extend.none)
            if show_labels
                lb_ap_H_75 := label.new(bar_index + 2, asiaProj_H_75,
                     "Asia Proj H 75p  " + f_pctStr(f_pct(asiaProj_H_75, asiaLRef)),
                     style=label.style_label_left, color=apLbBg,
                     textcolor=apTxt, size=size.small)

        if not na(asiaProj_H_med)
            ln_ap_H_med := line.new(x1, asiaProj_H_med, x2, asiaProj_H_med,
                 color=apMedLineCol, width=1, style=apStyle,
                 xloc=xloc.bar_time, extend=extend.none)
            if show_labels
                lb_ap_H_med := label.new(bar_index + 2, asiaProj_H_med,
                     "Asia Proj H med  " + f_pctStr(f_pct(asiaProj_H_med, asiaLRef)),
                     style=label.style_label_left, color=apMedLbBg,
                     textcolor=apTxt, size=size.small)

        if not na(asiaProj_L_75)
            ln_ap_L_75 := line.new(x1, asiaProj_L_75, x2, asiaProj_L_75,
                 color=apLineCol, width=2, style=apStyle,
                 xloc=xloc.bar_time, extend=extend.none)
            if show_labels
                lb_ap_L_75 := label.new(bar_index + 2, asiaProj_L_75,
                     "Asia Proj L 75p  " + f_pctStr(f_pct(asiaProj_L_75, asiaHRef)),
                     style=label.style_label_left, color=apLbBg,
                     textcolor=apTxt, size=size.small)

        if not na(asiaProj_L_med)
            ln_ap_L_med := line.new(x1, asiaProj_L_med, x2, asiaProj_L_med,
                 color=apMedLineCol, width=1, style=apStyle,
                 xloc=xloc.bar_time, extend=extend.none)
            if show_labels
                lb_ap_L_med := label.new(bar_index + 2, asiaProj_L_med,
                     "Asia Proj L med  " + f_pctStr(f_pct(asiaProj_L_med, asiaHRef)),
                     style=label.style_label_left, color=apMedLbBg,
                     textcolor=apTxt, size=size.small)

        if asiaComplete
            // After Asia: actual Asia H/L + London extension targets
            if not na(asiaHigh)
                ln_aH := line.new(x1, asiaHigh, x2, asiaHigh,
                     color=col_asia, width=1, style=line.style_dotted,
                     xloc=xloc.bar_time, extend=extend.none)
                if show_labels
                    lb_aH := label.new(bar_index + 2, asiaHigh,
                         "Asia High  " + str.tostring(math.round(asiaHigh, 2)),
                         style=label.style_label_left, color=color.new(col_asia, 70),
                         textcolor=color.white, size=size.small)

            if not na(asiaLow)
                ln_aL := line.new(x1, asiaLow, x2, asiaLow,
                     color=col_asia, width=1, style=line.style_dotted,
                     xloc=xloc.bar_time, extend=extend.none)
                if show_labels
                    lb_aL := label.new(bar_index + 2, asiaLow,
                         "Asia Low   " + str.tostring(math.round(asiaLow, 2)),
                         style=label.style_label_left, color=color.new(col_asia, 70),
                         textcolor=color.white, size=size.small)

            // London extension 75th — primary target levels
            if not na(lonExt_H_75)
                ln_lE_H75 := line.new(x1, lonExt_H_75, x2, lonExt_H_75,
                     color=col_london, width=2, style=line.style_dashed,
                     xloc=xloc.bar_time, extend=extend.none)
                if show_labels
                    remPct = math.round(remainingPts_75 / dayOpen * 100, 2)
                    lb_lE_H75 := label.new(bar_index + 2, lonExt_H_75,
                         "London Ext H 75p  +" + str.tostring(remPct) + "% from Asia High",
                         style=label.style_label_left, color=color.new(col_london, 70),
                         textcolor=color.white, size=size.small)

            if not na(lonExt_L_75)
                ln_lE_L75 := line.new(x1, lonExt_L_75, x2, lonExt_L_75,
                     color=col_london, width=2, style=line.style_dashed,
                     xloc=xloc.bar_time, extend=extend.none)
                if show_labels
                    remPct = math.round(remainingPts_75 / dayOpen * 100, 2)
                    lb_lE_L75 := label.new(bar_index + 2, lonExt_L_75,
                         "London Ext L 75p  -" + str.tostring(remPct) + "% from Asia Low",
                         style=label.style_label_left, color=color.new(col_london, 70),
                         textcolor=color.white, size=size.small)

            // London extension median — secondary / conservative target
            if not na(lonExt_H_med)
                ln_lE_Hmd := line.new(x1, lonExt_H_med, x2, lonExt_H_med,
                     color=color.new(col_london, 55), width=1, style=line.style_dashed,
                     xloc=xloc.bar_time, extend=extend.none)

            if not na(lonExt_L_med)
                ln_lE_Lmd := line.new(x1, lonExt_L_med, x2, lonExt_L_med,
                     color=color.new(col_london, 55), width=1, style=line.style_dashed,
                     xloc=xloc.bar_time, extend=extend.none)

            // London O-C targets — from Asia close, using session O-C % of daily range
            lonOCCol75  = color.new(color.teal, 0)
            lonOCColMed = color.new(color.teal, 55)
            if not na(lonOC_H_75)
                ln_lOC_H75 := line.new(x1, lonOC_H_75, x2, lonOC_H_75,
                     color=lonOCCol75, width=2, style=line.style_solid,
                     xloc=xloc.bar_time, extend=extend.none)
                if show_labels
                    ocPct = math.round(lonOC_pts_75 / dayOpen * 100, 2)
                    lb_lOC_H75 := label.new(bar_index + 2, lonOC_H_75,
                         "Lon O-C H 75p  +" + str.tostring(ocPct) + "% from Asia close",
                         style=label.style_label_left, color=color.new(color.teal, 70),
                         textcolor=color.white, size=size.small)

            if not na(lonOC_L_75)
                ln_lOC_L75 := line.new(x1, lonOC_L_75, x2, lonOC_L_75,
                     color=lonOCCol75, width=2, style=line.style_solid,
                     xloc=xloc.bar_time, extend=extend.none)
                if show_labels
                    ocPct = math.round(lonOC_pts_75 / dayOpen * 100, 2)
                    lb_lOC_L75 := label.new(bar_index + 2, lonOC_L_75,
                         "Lon O-C L 75p  -" + str.tostring(ocPct) + "% from Asia close",
                         style=label.style_label_left, color=color.new(color.teal, 70),
                         textcolor=color.white, size=size.small)

            if not na(lonOC_H_med)
                ln_lOC_Hmd := line.new(x1, lonOC_H_med, x2, lonOC_H_med,
                     color=lonOCColMed, width=1, style=line.style_solid,
                     xloc=xloc.bar_time, extend=extend.none)

            if not na(lonOC_L_med)
                ln_lOC_Lmd := line.new(x1, lonOC_L_med, x2, lonOC_L_med,
                     color=lonOCColMed, width=1, style=line.style_solid,
                     xloc=xloc.bar_time, extend=extend.none)

    // ── OH/OL labels + Drift forecast arrow ──────────────────────────────────
    if show_oh_ol_drift
        if show_labels
            if not na(oh_up_75)
                lb_oh_up_75 := label.new(bar_index + 2, oh_up_75,
                     "OH 75p  +" + str.tostring(vol_oh_75) + "%",
                     style=label.style_label_left, color=color.new(col_oh_75, 70),
                     textcolor=color.white, size=size.small)
            if not na(oh_up_med)
                lb_oh_up_med := label.new(bar_index + 2, oh_up_med,
                     "OH med  +" + str.tostring(vol_oh_med) + "%",
                     style=label.style_label_left, color=color.new(col_oh_med, 70),
                     textcolor=color.white, size=size.small)
            if not na(ol_dn_75)
                lb_ol_dn_75 := label.new(bar_index + 2, ol_dn_75,
                     "OL 75p  -" + str.tostring(vol_ol_75) + "%",
                     style=label.style_label_left, color=color.new(col_ol_75, 70),
                     textcolor=color.white, size=size.small)
            if not na(ol_dn_med)
                lb_ol_dn_med := label.new(bar_index + 2, ol_dn_med,
                     "OL med  -" + str.tostring(vol_ol_med) + "%",
                     style=label.style_label_left, color=color.new(col_ol_med, 70),
                     textcolor=color.white, size=size.small)

        // Drift forecast arrow — from session open, sloped by drift × OC 75th range
        // The line spans one full day (24 h) in time so the angle is timeframe-agnostic.
        if not na(drift_val) and not na(dayOpen)
            // Scale: drift of ±1.0 maps to ±1× the OC 75th expected move.
            // Falls back to OC med, then to 1% of price if neither is available.
            ocRef       = not na(vol_oc_75)  ? vol_oc_75  :
                          not na(vol_oc_med) ? vol_oc_med : 1.0
            ocPts       = dayOpen * ocRef / 100
            driftEnd    = dayOpen + drift_val * ocPts

            driftColor  = drift_val >= 0.3  ? color.new(color.lime,   0)  :
                          drift_val >= 0.1  ? color.new(color.green,  10) :
                          drift_val > -0.1  ? color.new(color.gray,   30) :
                          drift_val > -0.3  ? color.new(color.orange, 10) :
                                              color.new(color.red,     0)

            dayDurMs    = 24 * 60 * 60 * 1000
            ln_drift   := line.new(dayStartTime, dayOpen,
                          dayStartTime + dayDurMs, driftEnd,
                          color=driftColor, width=2, style=line.style_arrow_right,
                          xloc=xloc.bar_time, extend=extend.none)

            if show_labels
                driftTag = drift_val >= 0.3  ? "Bullish ↑"         :
                           drift_val >= 0.1  ? "Mild bullish ↑"    :
                           drift_val > -0.1  ? "Neutral"            :
                           drift_val > -0.3  ? "Mild bearish ↓"    :
                                               "Bearish ↓"
                lb_drift := label.new(bar_index + 2, driftEnd,
                     "Drift " + str.tostring(math.round(drift_val, 3)) + "  " + driftTag,
                     style=label.style_label_left, color=color.new(driftColor, 70),
                     textcolor=color.white, size=size.small)

// =====================================================
// LIVE STATS TABLE
// =====================================================

var table statsTable = na

if show_table and barstate.islast
    table.delete(statsTable)

    // Extra rows when session stats are present
    extraRows = sessionStatsFound ? 3 : 0
    statsTable := table.new(position.top_right, 2, 4 + extraRows,
         bgcolor=color.new(color.black, 55),
         border_width=1, border_color=color.new(color.gray, 60),
         frame_width=1,  frame_color=color.new(color.gray, 50))

    table.cell(statsTable, 0, 0, "Range",    text_color=color.new(color.white, 30), text_size=size.small, bgcolor=color.new(color.gray, 75))
    table.cell(statsTable, 1, 0, "%",        text_color=color.new(color.white, 30), text_size=size.small, bgcolor=color.new(color.gray, 75))

    liveCol = liveHL_pct >= vol_hl_75 ? color.red : liveHL_pct >= vol_hl_med ? color.orange : color.green
    table.cell(statsTable, 0, 1, "Live",     text_color=color.white, text_size=size.small, bgcolor=liveCol)
    table.cell(statsTable, 1, 1, str.tostring(liveHL_pct) + "%", text_color=color.white, text_size=size.small, bgcolor=liveCol)

    table.cell(statsTable, 0, 2, "Median",   text_color=color.new(color.white, 20), text_size=size.small, bgcolor=color.new(color.gray, 75))
    table.cell(statsTable, 1, 2, not na(vol_hl_med) ? str.tostring(vol_hl_med) + "%" : "—", text_color=color.new(color.white, 20), text_size=size.small, bgcolor=color.new(color.gray, 75))

    table.cell(statsTable, 0, 3, "75th Pct", text_color=color.new(color.orange, 10), text_size=size.small, bgcolor=color.new(color.gray, 75))
    table.cell(statsTable, 1, 3, not na(vol_hl_75) ? str.tostring(vol_hl_75) + "%" : "—", text_color=color.new(color.orange, 10), text_size=size.small, bgcolor=color.new(color.gray, 75))

    if sessionStatsFound
        asiaActPctOfDay = not na(asiaActualPts) and not na(dailyPts_med) and dailyPts_med > 0
             ? math.round(asiaActualPts / dailyPts_med * 100, 0) : float(na)
        asiaRowLbl = asiaComplete ? "Asia (done)" : "Asia (live)"
        asiaBg     = asiaComplete ? color.new(color.gray, 75) : color.new(color.blue, 55)
        table.cell(statsTable, 0, 4, asiaRowLbl,
             text_color=color.new(color.blue, 0), text_size=size.small, bgcolor=asiaBg)
        table.cell(statsTable, 1, 4,
             not na(asiaActualPts) ? str.tostring(math.round(asiaActualPts / dayOpen * 100, 2)) + "%" : "—",
             text_color=color.new(color.blue, 0), text_size=size.small, bgcolor=asiaBg)

        remPctMed = not na(remainingPts_med) ? math.round(remainingPts_med / dayOpen * 100, 2) : float(na)
        table.cell(statsTable, 0, 5, "Rem (med)",
             text_color=color.new(color.green, 10), text_size=size.small, bgcolor=color.new(color.gray, 75))
        table.cell(statsTable, 1, 5,
             not na(remPctMed) ? str.tostring(remPctMed) + "%" : "—",
             text_color=color.new(color.green, 10), text_size=size.small, bgcolor=color.new(color.gray, 75))

        remPct75 = not na(remainingPts_75) ? math.round(remainingPts_75 / dayOpen * 100, 2) : float(na)
        table.cell(statsTable, 0, 6, "Rem (75p)",
             text_color=color.new(color.green, 10), text_size=size.small, bgcolor=color.new(color.gray, 75))
        table.cell(statsTable, 1, 6,
             not na(remPct75) ? str.tostring(remPct75) + "%" : "—",
             text_color=color.new(color.green, 10), text_size=size.small, bgcolor=color.new(color.gray, 75))
