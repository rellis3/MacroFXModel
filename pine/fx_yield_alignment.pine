//@version=5
indicator("FX Price vs Yield Spread", overlay=false, max_bars_back=500)

// ─── Inputs ───────────────────────────────────────────────────────────────────
int   normLen  = input.int(50,   "Normalisation window (bars)", minval=10,
                 tooltip="Z-score window — scales both series to the same range")
int   slopeLen = input.int(5,    "Slope lookback (bars)",       minval=1,
                 tooltip="Used for direction detection only")
float divThr   = input.float(0.5, "Divergence threshold (z-units)", minval=0.1, step=0.1,
                 tooltip="Difference beyond this = RED (diverging). Within = GREEN (aligned)")

// Show/hide the three lines independently
bool  showPrice  = input.bool(true,  "Show Price Z-score",         group="Visibility")
bool  showYield  = input.bool(true,  "Show Yield Spread Z-score",  group="Visibility")
bool  showDiff   = input.bool(true,  "Show Difference (Price − Yield)", group="Visibility")
bool  showBands  = input.bool(true,  "Show threshold bands",        group="Visibility")
bool  showBG     = input.bool(true,  "Show background shading",     group="Visibility")
bool  showTable  = input.bool(true,  "Show info table",             group="Visibility")

// ─── Pre-load all 8 major 10Y yields ─────────────────────────────────────────
float yUSD = request.security("TVC:US10Y", timeframe.period, close, ignore_invalid_symbol=true)
float yEUR = request.security("TVC:EU10Y", timeframe.period, close, ignore_invalid_symbol=true)
float yGBP = request.security("TVC:GB10Y", timeframe.period, close, ignore_invalid_symbol=true)
float yJPY = request.security("TVC:JP10Y", timeframe.period, close, ignore_invalid_symbol=true)
float yAUD = request.security("TVC:AU10Y", timeframe.period, close, ignore_invalid_symbol=true)
float yCAD = request.security("TVC:CA10Y", timeframe.period, close, ignore_invalid_symbol=true)
float yCHF = request.security("TVC:CH10Y", timeframe.period, close, ignore_invalid_symbol=true)
float yNZD = request.security("TVC:NZ10Y", timeframe.period, close, ignore_invalid_symbol=true)

// ─── Auto-select yields from the current pair ─────────────────────────────────
f_yieldForCcy(string ccy) =>
    switch ccy
        "USD" => yUSD
        "EUR" => yEUR
        "GBP" => yGBP
        "JPY" => yJPY
        "AUD" => yAUD
        "CAD" => yCAD
        "CHF" => yCHF
        "NZD" => yNZD
        => float(na)

float baseY  = f_yieldForCcy(syminfo.basecurrency)
float quoteY = f_yieldForCcy(syminfo.currency)
float spread = baseY - quoteY   // e.g. EUR/USD → EU10Y − US10Y

bool   autoDetected = not na(baseY) and not na(quoteY)
string spreadLabel  = syminfo.basecurrency + "10Y − " + syminfo.currency + "10Y"

// ─── Z-score normalisation ────────────────────────────────────────────────────
float pMean   = ta.sma(close,  normLen)
float pStd    = ta.stdev(close,  normLen)
float priceZ  = pStd  != 0 ? (close  - pMean)  / pStd  : 0.0

float sMean   = ta.sma(spread, normLen)
float sStd    = ta.stdev(spread, normLen)
float spreadZ = sStd  != 0 ? (spread - sMean)  / sStd  : 0.0

// ─── Difference ───────────────────────────────────────────────────────────────
// Near 0   → price and yield moving together (aligned)
// Large +  → price running above yields (e.g. EUR/USD up but EU-US spread not supporting)
// Large -  → yields running above price  (yield moving before price catches up)
float diff = priceZ - spreadZ

// Converging = difference is shrinking back toward zero
bool converging = math.abs(diff) < math.abs(diff[slopeLen])
bool aligned    = math.abs(diff) < divThr

// ─── Difference line colour ───────────────────────────────────────────────────
// Green = within threshold (aligned)   Red = outside threshold (diverging)
// Shade slightly lighter if converging back from a diverged state
color diffCol = aligned  ? color.new(color.lime, 0) :
                converging ? color.new(color.orange, 0) :
                             color.new(color.red,  0)

// ─── Rolling alignment score ──────────────────────────────────────────────────
float alignScore = ta.sma(aligned ? 1.0 : 0.0, normLen) * 100

// ─── Plots ────────────────────────────────────────────────────────────────────
plot(showPrice ? priceZ  : na, "Price Z-score",        color=color.new(color.blue,  0), linewidth=2)
plot(showYield ? spreadZ : na, "Yield Spread Z-score", color=color.new(color.white, 0), linewidth=2)
plot(showDiff  ? diff    : na, "Divergence (P − Y)",   color=diffCol,                   linewidth=2)

// Zero line and threshold bands
hline(0, "Zero", color=color.new(color.gray, 50), linestyle=hline.style_dashed)
h1 =  hline(showBands ?  divThr : na, "+Threshold", color=color.new(color.red, 60), linestyle=hline.style_dotted)
h2 =  hline(showBands ? -divThr : na, "−Threshold", color=color.new(color.red, 60), linestyle=hline.style_dotted)
fill(h1, h2, color=color.new(color.green, 96), title="Aligned zone")

// Background: green when aligned, red when diverging
bgcolor(showBG and aligned      ? color.new(color.green, 93) :
        showBG and not aligned  ? color.new(color.red,   93) : na,
        title="Alignment BG")

// ─── Info table ───────────────────────────────────────────────────────────────
if showTable and barstate.islast
    var table t = table.new(position.top_right, 2, 5,
                             frame_color=color.new(color.gray, 40), frame_width=1,
                             border_color=color.new(color.gray, 60), border_width=1)
    color hdr = color.new(#1e222d, 0)
    color blk = color.new(color.black, 0)

    table.cell(t, 0, 0, "Spread",    text_color=color.silver, bgcolor=hdr, text_size=size.small)
    table.cell(t, 1, 0, autoDetected ? spreadLabel : "⚠ unknown pair",
                 text_color=autoDetected ? color.white : color.orange,
                 bgcolor=blk, text_size=size.small)

    table.cell(t, 0, 1, "Spread now", text_color=color.white, bgcolor=hdr, text_size=size.small)
    table.cell(t, 1, 1, str.tostring(spread, "#.##") + "%",
                 text_color=color.white, bgcolor=blk, text_size=size.small)

    table.cell(t, 0, 2, "Diff (P−Y)", text_color=color.white, bgcolor=hdr, text_size=size.small)
    table.cell(t, 1, 2, str.tostring(diff, "#.##"),
                 text_color=math.abs(diff) < divThr ? color.lime :
                            converging              ? color.orange : color.red,
                 bgcolor=blk, text_size=size.small)

    table.cell(t, 0, 3, "State",      text_color=color.white, bgcolor=hdr, text_size=size.small)
    table.cell(t, 1, 3, aligned ? "ALIGNED" : converging ? "CONVERGING" : "DIVERGING",
                 text_color=aligned ? color.lime : converging ? color.orange : color.red,
                 bgcolor=blk, text_size=size.small)

    table.cell(t, 0, 4, "Align% (" + str.tostring(normLen) + "b)",
                 text_color=color.white, bgcolor=hdr, text_size=size.small)
    table.cell(t, 1, 4, str.tostring(math.round(alignScore, 1)) + "%",
                 text_color=alignScore > 60 ? color.lime : alignScore < 40 ? color.red : color.gray,
                 bgcolor=blk, text_size=size.small)

// ─── Reading guide ────────────────────────────────────────────────────────────
// BLUE  = Price z-score
// WHITE = Yield Spread z-score  (base 10Y − quote 10Y, e.g. EU10Y − US10Y for EUR/USD)
// GREEN diff line  = within threshold — price and yield spread aligned
// ORANGE diff line = outside threshold but converging back (potential re-alignment)
// RED diff line    = outside threshold and still diverging
//
// Diff above zero → price running ahead of yields (yields not confirming the move)
// Diff below zero → yields running ahead of price  (price lagging the yield signal)
