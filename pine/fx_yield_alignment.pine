//@version=5
indicator("FX Price vs Yield Spread", overlay=false, max_bars_back=500)

// ─── Inputs ───────────────────────────────────────────────────────────────────
int   trendLen  = input.int(20,  "Trend smoothing (bars)", minval=3,
                  tooltip="EMA applied to price AND yield before comparison. On 5m: 20 = ~1.5h, 60 = ~5h. Raise to reduce reactivity.")
int   normLen   = input.int(100, "Normalisation window (bars)", minval=20,
                  tooltip="How many bars of history to z-score against. Longer = more stable scale.")
float alignThr  = input.float(0.5,  "Aligned threshold (z-units)",    minval=0.1, step=0.05,
                  tooltip="Diff below this = GREEN (aligned).")
float divThr    = input.float(0.85, "Divergence threshold (z-units)", minval=0.1, step=0.05,
                  tooltip="Diff above this = RED (diverging). The gap between this and the aligned threshold is the orange caution band.")

bool  showPrice  = input.bool(true,  "Show Price trend",        group="Visibility")
bool  showYield  = input.bool(true,  "Show Yield Spread trend", group="Visibility")
bool  showDiff   = input.bool(true,  "Show Difference line",    group="Visibility")
bool  showBands  = input.bool(true,  "Show threshold bands",    group="Visibility")
bool  showBG     = input.bool(true,  "Show background",         group="Visibility")
bool  showTable  = input.bool(true,  "Show info table",         group="Visibility")

// ─── Pre-load all 8 major 10Y yields ─────────────────────────────────────────
// Always request at chart timeframe — the daily yield data forward-fills cleanly
// into intraday bars. EMA smoothing below handles the step-function shape.
float yUSD = request.security("TVC:US10Y", timeframe.period, close, ignore_invalid_symbol=true)
float yEUR = request.security("TVC:EU10Y", timeframe.period, close, ignore_invalid_symbol=true)
float yGBP = request.security("TVC:GB10Y", timeframe.period, close, ignore_invalid_symbol=true)
float yJPY = request.security("TVC:JP10Y", timeframe.period, close, ignore_invalid_symbol=true)
float yAUD = request.security("TVC:AU10Y", timeframe.period, close, ignore_invalid_symbol=true)
float yCAD = request.security("TVC:CA10Y", timeframe.period, close, ignore_invalid_symbol=true)
float yCHF = request.security("TVC:CH10Y", timeframe.period, close, ignore_invalid_symbol=true)
float yNZD = request.security("TVC:NZ10Y", timeframe.period, close, ignore_invalid_symbol=true)

// ─── Auto-select yields from pair ────────────────────────────────────────────
f_yieldForCcy(string ccy) =>
    switch ccy
        "USD" => yUSD
        "EUR" => yEUR
        "GBP" => yGBP
        "JPY" => yJPY
        "AUD" => yAUD
        "CAD" => yCAD
        "CHF" => yCHF
        "NZD" => yNZD
        => float(na)

float baseY  = f_yieldForCcy(syminfo.basecurrency)
float quoteY = f_yieldForCcy(syminfo.currency)
float spread = baseY - quoteY

bool   autoDetected = not na(baseY) and not na(quoteY)
string spreadLabel  = syminfo.basecurrency + "10Y − " + syminfo.currency + "10Y"

// ─── Smooth both series before comparing ─────────────────────────────────────
// This is the key step that stops the indicator behaving like an oscillator.
// EMA on close gives the price *trend* over trendLen bars.
// EMA on the yield spread smooths out the daily step-change shape on intraday charts.
// We compare trends to trends, not individual bars to individual bars.
float smoothPrice  = ta.ema(close,  trendLen)
float smoothSpread = ta.ema(spread, trendLen)

// ─── Z-score the smoothed series ─────────────────────────────────────────────
// Puts both on the same scale so we can overlay and diff them
float pMean   = ta.sma(smoothPrice,  normLen)
float pStd    = ta.stdev(smoothPrice,  normLen)
float priceZ  = pStd  != 0 ? (smoothPrice  - pMean)  / pStd  : 0.0

float sMean   = ta.sma(smoothSpread, normLen)
float sStd    = ta.stdev(smoothSpread, normLen)
float spreadZ = sStd  != 0 ? (smoothSpread - sMean)  / sStd  : 0.0

// ─── Difference ───────────────────────────────────────────────────────────────
// Measures sustained structural divergence between the two trend lines.
// Near 0   = price trend and yield trend moving together
// Large +  = price trend running above yield trend (price leading, not yield-confirmed)
// Large -  = yield trend running above price trend (yield leading, price lagging)
float diff = priceZ - spreadZ

// Two-threshold band: orange is only the narrow zone between align and div thresholds.
// This keeps orange brief — it only appears when crossing between green and red.
bool aligned  = math.abs(diff) < alignThr
bool caution  = math.abs(diff) >= alignThr and math.abs(diff) < divThr
bool diverged = math.abs(diff) >= divThr

// ─── Colours ──────────────────────────────────────────────────────────────────
color diffCol = aligned  ? color.new(color.lime,   0) :
                caution  ? color.new(color.orange, 0) :
                           color.new(color.red,    0)

float alignScore = ta.sma(aligned ? 1.0 : 0.0, normLen) * 100

// ─── Plots ────────────────────────────────────────────────────────────────────
plot(showPrice ? priceZ  : na, "Price trend (z)",        color=color.new(color.blue,  0), linewidth=2)
plot(showYield ? spreadZ : na, "Yield Spread trend (z)", color=color.new(color.white, 0), linewidth=2)
plot(showDiff  ? diff    : na, "Divergence (P − Y)",     color=diffCol,                   linewidth=2)

hline(0, "Zero", color=color.new(color.gray, 50), linestyle=hline.style_dashed)
h1 = hline(showBands ?  divThr  : na, "+Div",    color=color.new(color.red,    60), linestyle=hline.style_dotted)
h2 = hline(showBands ? -divThr  : na, "−Div",    color=color.new(color.red,    60), linestyle=hline.style_dotted)
h3 = hline(showBands ?  alignThr : na, "+Align", color=color.new(color.green,  60), linestyle=hline.style_dotted)
h4 = hline(showBands ? -alignThr : na, "−Align", color=color.new(color.green,  60), linestyle=hline.style_dotted)
fill(h3, h4, color=color.new(color.green, 96), title="Aligned zone")
fill(h1, h3, color=color.new(color.orange, 97), title="Caution zone +")
fill(h4, h2, color=color.new(color.orange, 97), title="Caution zone −")

bgcolor(showBG and aligned  ? color.new(color.green,  93) :
        showBG and caution  ? color.new(color.orange, 96) :
        showBG and diverged ? color.new(color.red,    93) : na)

// ─── Info table ───────────────────────────────────────────────────────────────
if showTable and barstate.islast
    var table t = table.new(position.top_right, 2, 5,
                             frame_color=color.new(color.gray, 40), frame_width=1,
                             border_color=color.new(color.gray, 60), border_width=1)
    color hdr = color.new(#1e222d, 0)
    color blk = color.new(color.black, 0)

    table.cell(t, 0, 0, "Spread",       text_color=color.silver, bgcolor=hdr, text_size=size.small)
    table.cell(t, 1, 0, autoDetected ? spreadLabel : "⚠ unknown pair",
                 text_color=autoDetected ? color.white : color.orange,
                 bgcolor=blk, text_size=size.small)

    table.cell(t, 0, 1, "Spread now",   text_color=color.white,  bgcolor=hdr, text_size=size.small)
    table.cell(t, 1, 1, str.tostring(spread, "#.##") + "%",
                 text_color=color.white, bgcolor=blk, text_size=size.small)

    table.cell(t, 0, 2, "Diff (P−Y)",  text_color=color.white,  bgcolor=hdr, text_size=size.small)
    table.cell(t, 1, 2, str.tostring(diff, "#.##"),
                 text_color=aligned ? color.lime : caution ? color.orange : color.red,
                 bgcolor=blk, text_size=size.small)

    table.cell(t, 0, 3, "State",        text_color=color.white,  bgcolor=hdr, text_size=size.small)
    table.cell(t, 1, 3, aligned ? "ALIGNED" : caution ? "CAUTION" : "DIVERGING",
                 text_color=aligned ? color.lime : caution ? color.orange : color.red,
                 bgcolor=blk, text_size=size.small)

    table.cell(t, 0, 4, "Align% (" + str.tostring(normLen) + "b)",
                 text_color=color.white, bgcolor=hdr, text_size=size.small)
    table.cell(t, 1, 4, str.tostring(math.round(alignScore, 1)) + "%",
                 text_color=alignScore > 60 ? color.lime : alignScore < 40 ? color.red : color.gray,
                 bgcolor=blk, text_size=size.small)

// ─── Reading guide ────────────────────────────────────────────────────────────
// BLUE  = Smoothed price trend, z-scored
// WHITE = Smoothed yield spread trend, z-scored
// GREEN  diff = trends aligned (price and yield moving together sustainably)
// ORANGE diff = diverged but converging back (re-alignment underway)
// RED    diff = trends diverging (price running away from yield or vice versa)
//
// Diff above 0 → price trend running above yield trend (move not yield-confirmed)
// Diff below 0 → yield trend running above price trend (yield leading, price may follow)
//
// Tuning for timeframes:
//   5m  chart → trendLen 20–40  (1.5–3h of smoothing)
//   15m chart → trendLen 8–16   (2–4h of smoothing)
//   1h  chart → trendLen 4–8    (4–8h of smoothing)
